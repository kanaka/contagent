ARG RUST_VERSION

ENV RUSTUP_HOME=/usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
ENV CARGO_INSTALL_ROOT=/var/cache/contagent/cargo-install
ENV PATH=${CARGO_INSTALL_ROOT}/bin:/usr/local/cargo/bin:${PATH}

RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --default-toolchain "${RUST_VERSION}" --profile minimal \
    && chmod -R a+rwX "${RUSTUP_HOME}" "${CARGO_HOME}" \
    && install -d "${CARGO_INSTALL_ROOT}" \
    && ln -sf /usr/local/cargo/bin/rustup /usr/local/bin/rustup \
    && ln -sf /usr/local/cargo/bin/cargo /usr/local/bin/cargo \
    && ln -sf /usr/local/cargo/bin/rustc /usr/local/bin/rustc \
    && ln -sf /usr/local/cargo/bin/rustfmt /usr/local/bin/rustfmt \
    && ln -sf /usr/local/cargo/bin/clippy-driver /usr/local/bin/clippy-driver \
    && printf '%s\n' 'case ":$PATH:" in *:/usr/local/cargo/bin:*) ;; *) PATH="/usr/local/cargo/bin:$PATH" ;; esac' 'case ":$PATH:" in *:${CARGO_INSTALL_ROOT}/bin:*) ;; *) PATH="${CARGO_INSTALL_ROOT}/bin:$PATH" ;; esac' 'export PATH' > /etc/profile.d/cargo-path.sh
